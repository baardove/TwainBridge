// Copy to Config/Release.xcconfig (kept out of source control) and fill in values.
// The update public key is the base64-encoded 32-byte Ed25519 public key printed
// by Scripts/sign-update-manifest.swift.

DEVELOPMENT_TEAM = YOUR_TEAM_ID
CODE_SIGN_IDENTITY = Developer ID Application
TWAINBRIDGE_UPDATE_FEED_URL = https://updates.example.com/twainbridge/manifest.json
TWAINBRIDGE_UPDATE_PUBLIC_KEY = BASE64_ED25519_PUBLIC_KEY
MARKETING_VERSION = 1.0.0
CURRENT_PROJECT_VERSION = 1
